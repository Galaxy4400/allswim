{% extends "layouts/base.njk" %}
{% from "macros/ui.njk" import button, card %}

{% block title %}Home — Site{% endblock %}

{% block content %}

  {# Hero: include a self-contained section component #}
  {% include "components/sections/hero.njk" %}

  {# Features: using the card macro directly on the page #}
  <section id="features" class="py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-center text-gray-900 mb-16">Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {{ card(
          title="Feature One",
          description="Describe your first feature here. Keep it short and clear.",
          link="#"
        ) }}
        {{ card(
          title="Feature Two",
          description="Another great feature that helps your users achieve their goals.",
          link="#"
        ) }}
        {{ card(
          title="Feature Three",
          description="One more reason to choose your product over the competition.",
          link="#"
        ) }}
      </div>
    </div>
  </section>

  {# CTA: inline section with macros #}
  <section id="cta" class="py-24">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-4xl font-bold text-gray-900 mb-6">Ready to start?</h2>
      <p class="text-xl text-gray-500 mb-10">Join thousands of users who already trust us.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        {{ button("Sign up free", "#", "primary", "lg") }}
        {{ button("Talk to sales", "#", "outline", "lg") }}
      </div>
    </div>
  </section>

{% endblock %}
