{% from "macros/ui.njk" import button %}

<section class="min-h-screen flex items-center pt-16">
  <div class="container mx-auto px-4 text-center">

    <p class="text-sm font-semibold text-blue-600 uppercase tracking-widest mb-4">
      Your tagline here
    </p>

    <h1 class="text-5xl md:text-7xl font-bold text-gray-900 leading-tight mb-6">
      Your headline <br />
      <span class="text-blue-600">goes here</span>
